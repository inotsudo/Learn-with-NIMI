# NIMIPIKO — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# ---- Supabase --------------------------------------------------------
# Project URL + anon key from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- App ---------------------------------------------------------------
# Public base URL of this deployment (used for payment redirects, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- OpenRouter (Talk to Nimi AI chat) ---------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---- Stripe (subscription checkout) ------------------------------------
# Used by app/api/create-checkout-session and app/api/webhooks/stripe.
# Note: price IDs (not product IDs) for the monthly/yearly plans.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# ---- Flutterwave (mobile money — planned, not yet wired to a frontend flow) ----
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...

# ---- Web Push notifications (VAPID) -------------------------------------
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:support@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...

# ---- Cron (Vercel scheduled jobs) ----------------------------------------
# Sent as a Bearer token by Vercel Cron; must match the cron config in vercel.json.
CRON_SECRET=your-cron-secret
