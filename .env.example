# NIMIPIKO — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# ---- Supabase --------------------------------------------------------
# Project URL + anon key from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ---------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production public URL (used in payment origin allow-list, OG tags, etc.)
NEXT_PUBLIC_APP_URL=https://nimipiko.com

# ---- OpenRouter (Talk to Nimi AI chat) ---------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# ---- Web Push notifications (VAPID) -------------------------------------
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:support@nimipiko.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...

# ---- Cron (Vercel scheduled jobs) ----------------------------------------
# Sent as a Bearer token by Vercel Cron; must match the cron config in vercel.json.
CRON_SECRET=your-cron-secret

# ---- CyberSource (card payments) -----------------------------------------
# Merchant credentials from CyberSource Business Center
CYBERSOURCE_MERCHANT_ID=your-merchant-id
CYBERSOURCE_KEY_ID=your-key-id
CYBERSOURCE_SECRET_KEY=your-secret-key
# RSA private key as a single-line string with literal \n between lines
# (Vercel env vars cannot contain real newlines — use \n as the escape)
# e.g.: -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
CYBERSOURCE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# "production" or "apitest" — MUST be set to "production" for live payments
CYBERSOURCE_ENVIRONMENT=apitest
CYBERSOURCE_HOST=apitest.cybersource.com
# Key serial / profile ID for Secure Acceptance
CYBERSOURCE_KEY_SERIAL=your-key-serial
CYBERSOURCE_SA_PROFILE_ID=your-sa-profile-id
# Webhook signature secret from CyberSource webhook settings
CYBERSOURCE_WEBHOOK_SECRET=your-webhook-secret

# ---- MTN Mobile Money (MoMo) ------------------------------------------
MTN_REQUEST_TOKEN_ENDPOINT=https://sandbox.momodeveloper.mtn.com/collection/token/
MTN_REQUEST_TO_PAY_ENDPOINT=https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay
MTN_TRANSACTION_STATUS_ENDPOINT=https://sandbox.momodeveloper.mtn.com/collection/v1_0/requesttopay
MTN_ACCOUNT_BALANCE_ENDPOINT=https://sandbox.momodeveloper.mtn.com/collection/v1_0/account/balance
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_API_USER=your-momo-api-user
MOMO_API_KEY=your-momo-api-key
MOMO_COLLECTION_PRIMARY_KEY=your-collection-primary-key
MOMO_COLLECTION_SECONDARY_KEY=your-collection-secondary-key
MOMO_DISBURSEMENT_PRIMARY_KEY=your-disbursement-primary-key
MOMO_DISBURSEMENT_SECONDARY_KEY=your-disbursement-secondary-key
MOMO_COLLECTION_ACTIVE_KEY=your-collection-active-key
MOMO_DISBURSEMENT_ACTIVE_KEY=your-disbursement-active-key
MOMO_ENV=sandbox

# ---- SendGrid (transactional emails) -----------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=support@nimipiko.com

# ---- SMTP (auth emails via Hostinger) ----------------------------------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@nimipiko.com
SMTP_PASS=your-hostinger-email-password

# ---- Supabase Auth email hook -----------------------------------------
# A secret you invent — set the same value in:
#   Supabase Dashboard → Auth → Hooks → Send Email → Bearer token
SUPABASE_AUTH_HOOK_SECRET=your-auth-hook-secret

# ---- Security ---------------------------------------------------------
# AES encryption key for vault operations (32 random bytes, hex-encoded)
MASTER_VAULT_KEY=your-32-byte-hex-key

# ---- Upstash Redis (distributed rate limiting) -------------------------
# Optional but strongly recommended for production.
# Without these the rate limiter falls back to per-instance in-memory state
# (resets on cold start, does not coordinate across Vercel instances).
# Create a Redis database at console.upstash.com, then paste the REST URL and token.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
